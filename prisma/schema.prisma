generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  phone     String
  age       Int?
  gender    String?
  address   String?
  photoUrl  String?
  condition String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  sessions     Session[]
  payments     Payment[]
  followUps    FollowUp[]

  @@index([name])
  @@index([phone])
}

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  dateTime  DateTime
  duration  Int      @default(30)
  status    String   @default("scheduled") // scheduled, completed, cancelled, no-show
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  session Session?

  @@index([patientId])
  @@index([dateTime])
  @@index([status])
}

model Session {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String   @unique
  treatmentType String
  bodyPart      String?
  notes         String?
  duration      Int
  date          DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  payment     Payment?

  @@index([patientId])
  @@index([date])
}

model Payment {
  id          String   @id @default(cuid())
  patientId   String
  sessionId   String   @unique
  amount      Float
  status      String   @default("pending") // pending, paid
  paymentDate DateTime?
  method      String   @default("cash")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
  @@index([paymentDate])
}

model FollowUp {
  id        String   @id @default(cuid())
  patientId String
  nextDate  DateTime
  reason    String?
  notes     String?
  status    String   @default("pending") // pending, completed, cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([nextDate])
  @@index([status])
}
